# ==========================================================
# ExpoTime CRM — متغيرات البيئة (انسخ هذا الملف إلى .env واملأ القيم)
# ==========================================================

# --- Gemini AI ---
# مطلوب لمكالمات الذكاء الاصطناعي (تنظيف البيانات، صياغة الإيميلات، التقارير)
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# اختياري: اسم نموذج Gemini المستخدم (افتراضي: gemini-3.5-flash)
GEMINI_MODEL=""

# --- عنوان التطبيق ---
APP_URL="MY_APP_URL"
# منفذ الخادم (افتراضي: 3000)
PORT="3000"

# --- المصادقة والأمان ---
# كلمة مرور المدير العام (مطلوبة لتفعيل دخول المدير — لا توجد قيمة افتراضية لأسباب أمنية)
MANAGER_USERNAME="admin"
MANAGER_PASSWORD=""
# بريد المدير لتسجيل الدخول عبر Google
MANAGER_EMAIL="nabilalzubair@gmail.com"
# سر توقيع توكن الجلسات (اضبطه بقيمة عشوائية طويلة لإبقاء الجلسات صالحة بعد إعادة التشغيل)
AUTH_SECRET=""
# مدة صلاحية التوكن بالثواني (افتراضي: 43200 = 12 ساعة)
TOKEN_TTL_SECONDS="43200"
# كلمة المرور الافتراضية للمندوبين الجدد (يُنصح بتغييرها — تُخزَّن مشفّرة دائماً)
DEFAULT_EMPLOYEE_PASSWORD="123456"
# رقم واتساب المدير لاستقبال إشعارات النظام (بصيغة دولية بدون +)
MANAGER_WHATSAPP="966551016181"
# أصول مسموح لها بالوصول عبر CORS (مفصولة بفواصل، أو * للسماح للجميع)
ALLOWED_ORIGINS=""
# الحد الأقصى لحجم الطلب (افتراضي: 25mb)
BODY_LIMIT="25mb"

# --- ربط قاعدة البيانات بـ Google Sheets (Service Account) ---
# معرّف ملف Google Sheet (الجزء بين /d/ و /edit في الرابط)
GOOGLE_SHEET_ID="1051_4gL-dAPark13F4c7fH3WIIQd-N0fZxonlbR9CTk"
# الطريقة 1: لصق محتوى ملف مفتاح حساب الخدمة كـ JSON في سطر واحد
GOOGLE_SERVICE_ACCOUNT_JSON=""
# الطريقة 2 (بديلة): مسار ملف مفتاح حساب الخدمة على القرص
GOOGLE_SERVICE_ACCOUNT_FILE=""

# --- Baserow (معطّل حالياً — اختياري) ---
BASEROW_API_TOKEN=""
BASEROW_DATABASE_ID=""
TABLE_COMPANIES_ID=""
TABLE_EMPLOYEES_ID=""
TABLE_FOLLOWUPS_ID=""
